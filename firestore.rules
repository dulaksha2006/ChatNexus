rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Bot/public read collections
    match /botTexts/{d}    { allow read: if true; allow write: if false; }
    match /languages/{d}   { allow read: if true; allow write: if false; }
    match /botCommands/{d} { allow read: if true; allow write: if false; }
    match /botMenus/{d}    { allow read: if true; allow write: if false; }

    // Backend-only (Admin SDK bypasses rules entirely)
    match /configs/{d}            { allow read, write: if false; }
    match /userPrefs/{d}          { allow read, write: if false; }
    match /pendingOtps/{d}        { allow read, write: if false; }
    match /blacklist/{d}          { allow read, write: if false; }
    match /emailVerifications/{d} { allow read, write: if false; }

    // Dashboard collections — open read for authenticated requests.
    // NOTE: Authentication is handled at the backend API layer (JWT).
    // These collections are only written by the backend (Admin SDK).
    // If you use Firebase custom auth tokens, replace `true` with
    // `request.auth != null` below.
    match /users/{d}     { allow read: if true; allow write: if false; }
    match /sessions/{d}  {
      allow read: if true;
      allow write: if false;
      match /messages/{m} { allow read: if true; allow write: if false; }
    }
    match /chats/{d}         { allow read: if true; allow write: if false; }
    match /notifications/{d}  { allow read: if true; allow write: if false; }

  }
}
